{
  "name": "prompt-optimizer",
  "version": "1.0.0",
  "description": "Empirical prompt structure optimizer - discovers the optimal rule set for how each LLM prefers to receive instructions by testing 1K-10K prompt patterns via OpenRouter",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/tui/app.ts",
    "tui": "tsx src/tui/app.ts",
    "dev": "tsx src/index.ts",
    "generate": "tsx src/index.ts generate",
    "evaluate": "tsx src/index.ts evaluate",
    "extract": "tsx src/index.ts extract",
    "rewrite": "tsx src/index.ts rewrite",
    "discover-models": "tsx src/index.ts discover-models",
    "full-pipeline": "tsx src/index.ts full-pipeline",
    "validate": "tsx scripts/validate-patterns.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ora": "^9.3.0",
    "p-limit": "^6.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
